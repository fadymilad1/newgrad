SECRET_KEY=django-insecure-change-this-in-production
DEBUG=True
DB_ENGINE=sqlite

# Database settings (PostgreSQL - for production)
# DB_ENGINE=postgresql
# DB_NAME=medify_db
# DB_USER=postgres
# DB_PASSWORD=your-password
# DB_HOST=localhost
# DB_PORT=5432

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000

# Hugging Face medical chatbot
HF_MEDICAL_MODEL_ID=microsoft/Phi-3-mini-4k-instruct
HUGGINGFACE_API_TOKEN=hf_your_real_token_here
# Optional override, normally derived from HF_MEDICAL_MODEL_ID
# HUGGINGFACE_API_URL=https://router.huggingface.co/v1/chat/completions
CHATBOT_HTTP_TIMEOUT=60
CHATBOT_STREAM_CHUNK_SIZE=28
